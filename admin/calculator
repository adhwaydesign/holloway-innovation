<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Estimate Calculator - The Holloway Innovation</title>
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;}
:root{--black:#0D0D0D;--orange:#E8541A;--o2:#FF7A45;--odim:rgba(232,84,26,.1);--white:#fff;--gray:#888;--dk:#444;--mid:#181818;--card:#1E1E1E;--border:#2C2C2C;--text:#BBB;--green:#27A060;--red:#C0392B;--yellow:#F5A623;}
body{background:var(--black);color:var(--text);font-family:'Poppins',sans-serif;font-weight:300;min-height:100vh;}
.app-nav{background:var(--mid);border-bottom:2px solid var(--orange);display:flex;align-items:stretch;position:sticky;top:0;z-index:200;}
.nav-logo{padding:0 14px;display:flex;align-items:center;border-right:1px solid var(--border);}
.nav-logo img{height:42px;width:42px;object-fit:contain;}
.nav-tabs{display:flex;flex:1;}
.ntab{flex:1;font-family:'Oswald',sans-serif;font-weight:400;font-size:.7rem;letter-spacing:.15em;text-transform:uppercase;color:var(--gray);padding:14px 8px;text-align:center;cursor:pointer;border:none;background:transparent;border-bottom:3px solid transparent;margin-bottom:-2px;transition:all .2s;}
.ntab.active{color:var(--orange);border-bottom-color:var(--orange);}
.panel{display:none;max-width:880px;margin:0 auto;padding:20px 18px 100px;}
.panel.active{display:block;}
.slabel{font-family:'Oswald',sans-serif;font-size:.58rem;letter-spacing:.28em;text-transform:uppercase;color:var(--orange);margin-bottom:8px;display:flex;align-items:center;gap:10px;}
.slabel::after{content:'';flex:1;height:1px;background:var(--border);}
.row2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.field{margin-bottom:12px;}
.field label{display:block;font-family:'Oswald',sans-serif;font-size:.56rem;letter-spacing:.2em;text-transform:uppercase;color:var(--dk);margin-bottom:5px;}
.req{color:var(--orange);}
.field input,.field select,.field textarea{width:100%;background:var(--card);border:1px solid var(--border);color:var(--white);font-family:'Poppins',sans-serif;font-size:.83rem;font-weight:300;border-radius:5px;padding:9px 12px;outline:none;transition:border-color .18s;-webkit-appearance:none;}
.field input:focus,.field select:focus,.field textarea:focus{border-color:var(--orange);}
.field select option{background:var(--black);}
.field textarea{min-height:65px;resize:vertical;}
.chips{display:flex;flex-wrap:wrap;gap:6px;margin-top:4px;}
.chip{font-size:.7rem;border:1px solid var(--border);border-radius:14px;padding:4px 12px;color:var(--gray);cursor:pointer;transition:all .15s;user-select:none;background:var(--card);}
.chip:hover{border-color:var(--orange);color:var(--o2);}
.chip.on{background:var(--orange);border-color:var(--orange);color:var(--white);font-weight:500;}
.job-lines{display:flex;flex-direction:column;gap:8px;margin-bottom:10px;}
.job-line{background:var(--card);border:1px solid var(--border);border-radius:8px;padding:12px 14px;}
.jl-top{display:grid;grid-template-columns:1fr 1fr auto auto;gap:8px;align-items:center;margin-bottom:8px;}
.jl-top select{background:var(--mid);border:1px solid var(--border);color:var(--white);font-family:'Poppins',sans-serif;font-size:.78rem;border-radius:4px;padding:7px 10px;outline:none;-webkit-appearance:none;width:100%;}
.jl-top select:focus{border-color:var(--orange);}
.jl-price{font-family:'Oswald',sans-serif;font-weight:700;font-size:.9rem;color:var(--orange);white-space:nowrap;text-align:right;}
.jl-remove{background:transparent;border:1px solid var(--border);color:var(--gray);border-radius:4px;width:26px;height:26px;cursor:pointer;font-size:.75rem;display:flex;align-items:center;justify-content:center;transition:all .18s;flex-shrink:0;}
.jl-remove:hover{border-color:var(--red);color:var(--red);}
.jl-surfaces{display:flex;flex-wrap:wrap;gap:5px;}
.surf-chip{font-size:.65rem;border:1px solid var(--border);border-radius:10px;padding:3px 10px;color:var(--gray);cursor:pointer;transition:all .14s;user-select:none;background:var(--mid);}
.surf-chip:hover{border-color:var(--orange);color:var(--o2);}
.surf-chip.on{background:var(--orange);border-color:var(--orange);color:var(--white);font-weight:500;}
.add-line-btn{background:transparent;border:1px dashed var(--border);color:var(--gray);border-radius:6px;padding:9px;width:100%;font-family:'Oswald',sans-serif;font-size:.68rem;letter-spacing:.14em;text-transform:uppercase;cursor:pointer;transition:all .18s;}
.add-line-btn:hover{border-color:var(--orange);color:var(--orange);}
.cat-tabs{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px;}
.cat-tab{font-family:'Oswald',sans-serif;font-size:.62rem;letter-spacing:.1em;text-transform:uppercase;border:1px solid var(--border);border-radius:4px;padding:6px 12px;cursor:pointer;background:transparent;color:var(--gray);transition:all .18s;}
.cat-tab.active{background:var(--orange);border-color:var(--orange);color:var(--white);}
.cat-panel{display:none;}
.cat-panel.active{display:block;}
.adder-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px;}
.adder{background:var(--card);border:1px solid var(--border);border-radius:7px;padding:11px 13px;display:flex;justify-content:space-between;align-items:center;cursor:pointer;transition:all .18s;}
.adder.on{border-color:var(--orange);background:var(--odim);}
.adder-name{font-size:.78rem;color:var(--white);}
.adder-sub{font-size:.62rem;color:var(--dk);margin-top:2px;}
.adder-amt{font-family:'Oswald',sans-serif;font-weight:700;font-size:.82rem;color:var(--orange);white-space:nowrap;margin-left:8px;flex-shrink:0;}
.adder.on .adder-amt{color:var(--green);}
.qty-wrap{display:none;margin-top:8px;align-items:center;gap:10px;}
.qty-wrap.show{display:flex;}
.qty-wrap label{font-family:'Oswald',sans-serif;font-size:.56rem;letter-spacing:.16em;text-transform:uppercase;color:var(--dk);white-space:nowrap;}
.qty-wrap input{background:var(--card);border:1px solid var(--border);color:var(--white);font-family:'Poppins',sans-serif;font-size:.85rem;border-radius:4px;padding:6px 10px;outline:none;width:80px;}
.qty-wrap input:focus{border-color:var(--orange);}
.live-total{background:var(--card);border:1px solid var(--orange);border-radius:10px;padding:18px;margin-top:20px;position:sticky;bottom:14px;box-shadow:0 8px 32px rgba(0,0,0,.7);}
.lt-rows{display:flex;flex-direction:column;gap:5px;margin-bottom:12px;}
.lt-row{display:flex;justify-content:space-between;font-size:.76rem;color:var(--gray);}
.lt-row.total{border-top:1px solid var(--border);padding-top:9px;margin-top:4px;}
.lt-row.total span:first-child{font-family:'Oswald',sans-serif;font-weight:700;font-size:.82rem;color:var(--white);text-transform:uppercase;letter-spacing:.1em;}
.lt-row.total span:last-child{font-family:'Oswald',sans-serif;font-weight:700;font-size:1.35rem;color:var(--orange);}
.lt-range{font-size:.65rem;color:var(--dk);text-align:right;margin-top:-6px;margin-bottom:10px;}
.save-btn{width:100%;background:var(--orange);color:var(--white);font-family:'Oswald',sans-serif;font-weight:700;font-size:.88rem;letter-spacing:.14em;text-transform:uppercase;border:none;border-radius:6px;padding:13px;cursor:pointer;transition:background .2s;}
.save-btn:hover{background:var(--o2);}
.save-btn:disabled{background:var(--dk);cursor:not-allowed;opacity:.6;}
.stats-bar{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:20px;}
.stat{background:var(--card);border:1px solid var(--border);border-radius:7px;padding:13px 15px;}
.stat-val{font-family:'Oswald',sans-serif;font-weight:700;font-size:1.35rem;color:var(--orange);line-height:1;}
.stat-label{font-size:.62rem;color:var(--dk);margin-top:4px;}
.filter-bar{display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap;}
.filter-bar input{flex:1;min-width:150px;background:var(--card);border:1px solid var(--border);color:var(--white);font-family:'Poppins',sans-serif;font-size:.8rem;border-radius:5px;padding:8px 12px;outline:none;}
.filter-bar input:focus{border-color:var(--orange);}
.filter-bar select{background:var(--card);border:1px solid var(--border);color:var(--gray);font-family:'Poppins',sans-serif;font-size:.76rem;border-radius:5px;padding:8px 12px;outline:none;-webkit-appearance:none;}
.est-list{display:flex;flex-direction:column;gap:8px;}
.est-card{background:var(--card);border:1px solid var(--border);border-radius:8px;padding:15px 17px;cursor:pointer;transition:border-color .18s;}
.est-card:hover{border-color:#3a3a3a;}
.est-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:7px;}
.est-client{font-size:.9rem;font-weight:500;color:var(--white);}
.est-amount{font-family:'Oswald',sans-serif;font-weight:700;font-size:1.05rem;color:var(--orange);}
.est-meta{display:flex;gap:8px;flex-wrap:wrap;align-items:center;}
.est-tag{font-size:.62rem;color:var(--dk);background:var(--mid);border:1px solid var(--border);border-radius:3px;padding:2px 7px;}
.badge{display:inline-block;font-family:'Oswald',sans-serif;font-size:.55rem;letter-spacing:.15em;text-transform:uppercase;padding:2px 8px;border-radius:10px;border:1px solid;}
.badge.pending{border-color:var(--yellow);color:var(--yellow);}
.badge.approved{border-color:var(--green);color:var(--green);}
.badge.declined{border-color:var(--red);color:var(--red);}
.est-actions{display:flex;gap:5px;margin-top:9px;}
.eact{font-family:'Oswald',sans-serif;font-size:.58rem;letter-spacing:.12em;text-transform:uppercase;border-radius:4px;padding:4px 11px;cursor:pointer;border:1px solid var(--border);background:transparent;color:var(--gray);transition:all .18s;}
.eact:hover{border-color:var(--orange);color:var(--orange);}
.eact.danger:hover{border-color:var(--red);color:var(--red);}
.empty-state{text-align:center;padding:50px 20px;color:var(--dk);}
.detail-box{background:var(--black);border:1px solid var(--border);border-radius:10px;padding:24px;margin-top:16px;display:none;}
.detail-box.open{display:block;}
.detail-row{display:flex;justify-content:space-between;padding:7px 0;font-size:.78rem;border-bottom:1px solid var(--border);}
.detail-row span:first-child{color:var(--gray);}
.detail-row span:last-child{color:var(--white);font-weight:500;text-align:right;}
.detail-total{font-family:'Oswald',sans-serif;font-weight:700;font-size:1.2rem;color:var(--orange);}
.det-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:18px;padding-bottom:14px;border-bottom:1px solid var(--border);}
.det-name{font-family:'Oswald',sans-serif;font-weight:700;font-size:1.1rem;color:var(--white);}
.det-close{background:transparent;border:1px solid var(--border);color:var(--gray);border-radius:4px;padding:5px 12px;cursor:pointer;font-family:'Oswald',sans-serif;font-size:.6rem;letter-spacing:.12em;text-transform:uppercase;transition:all .18s;}
.det-section-title{font-family:'Oswald',sans-serif;font-size:.58rem;letter-spacing:.22em;text-transform:uppercase;color:var(--orange);margin:14px 0 8px;}
.status-sel{background:var(--card);border:1px solid var(--border);color:var(--white);font-family:'Poppins',sans-serif;font-size:.78rem;border-radius:4px;padding:6px 10px;outline:none;-webkit-appearance:none;}
@media(max-width:580px){.row2,.adder-grid,.jl-top{grid-template-columns:1fr;}.stats-bar{grid-template-columns:1fr 1fr;}}
</style>
</head>
<body>

<nav class="app-nav">
  <div class="nav-logo"><img src="data:image/png;base64," alt="Holloway Innovation"></div>
  <div class="nav-tabs">
    <button class="ntab active" onclick="showPanel('calc',this)">Calculator</button>
    <button class="ntab" onclick="showPanel('files',this)">My Estimates</button>
  </div>
</nav>

<div class="panel active" id="panel-calc">
  <div style="margin-top:6px;">
    <div class="slabel">Client Info</div>
    <div class="row2">
      <div class="field"><label>Client Name <span class="req">*</span></label><input type="text" id="cName" placeholder="Full name" oninput="updateTotal()"></div>
      <div class="field"><label>Phone</label><input type="text" id="cPhone" placeholder="(216) 000-0000"></div>
    </div>
    <div class="row2">
      <div class="field"><label>Address</label><input type="text" id="cAddr" placeholder="Job address"></div>
      <div class="field"><label>Date</label><input type="text" id="cDate" readonly></div>
    </div>
    <div class="field"><label>Notes</label><textarea id="cNotes" placeholder="Client requests, special instructions..."></textarea></div>
  </div>

  <div style="margin-top:22px;">
    <div class="slabel">Painting Job Lines</div>
    <p style="font-size:.72rem;color:var(--dk);margin-bottom:10px;">Add one line per room or area. Pick room size then tap which surfaces need painting.</p>
    <div class="job-lines" id="jobLines"></div>
    <button class="add-line-btn" onclick="addLine()">+ Add Room / Area</button>
  </div>

  <div style="margin-top:22px;">
    <div class="slabel">Paint Situation</div>
    <div class="chips">
      <span class="chip on" onclick="chipSingle(this,'paintMode','client')">Client supplies paint</span>
      <span class="chip" onclick="chipSingle(this,'paintMode','us')">We supply paint (+markup)</span>
    </div>
    <input type="hidden" id="paintMode" value="client">
  </div>

  <div style="margin-top:22px;">
    <div class="slabel">Add-Ons &amp; Other Services</div>
    <div class="cat-tabs">
      <button class="cat-tab active" onclick="showCat('conditions',this)">Wall Conditions</button>
      <button class="cat-tab" onclick="showCat('repairs',this)">Repairs</button>
      <button class="cat-tab" onclick="showCat('hanging',this)">Hanging &amp; Mounting</button>
      <button class="cat-tab" onclick="showCat('other',this)">Other</button>
    </div>
    <div class="cat-panel active" id="cat-conditions">
      <div class="adder-grid">
        <div class="adder" onclick="toggleAdder(this)" data-min="25" data-max="50" data-label="High Ceilings 9-10ft"><div><div class="adder-name">High Ceilings (9-10ft)</div><div class="adder-sub">Extra ladder time per room</div></div><div class="adder-amt">+$25-50/room</div></div>
        <div class="adder" onclick="toggleAdder(this)" data-min="50" data-max="100" data-label="Vaulted Ceilings"><div><div class="adder-name">Vaulted / 10ft+ Ceilings</div><div class="adder-sub">High or angled surfaces</div></div><div class="adder-amt">+$50-100/room</div></div>
        <div class="adder" onclick="toggleAdder(this)" data-min="30" data-max="60" data-label="Moving Furniture"><div><div class="adder-name">Moving Furniture</div><div class="adder-sub">Move and cover per room</div></div><div class="adder-amt">+$30-60/room</div></div>
        <div class="adder" onclick="toggleAdder(this)" data-min="50" data-max="100" data-label="Smoke or Water Stains"><div><div class="adder-name">Smoke / Water Stains</div><div class="adder-sub">Specialty primer needed</div></div><div class="adder-amt">+$50-100</div></div>
        <div class="adder" onclick="toggleAdder(this)" data-min="0" data-max="0" data-label="Rush Surcharge" data-pct="0.15"><div><div class="adder-name">Rush Job</div><div class="adder-sub">Scheduling within 3 days</div></div><div class="adder-amt">+15%</div></div>
        <div class="adder" onclick="toggleAdder(this)" data-min="15" data-max="25" data-label="Paint Sourcing Trip"><div><div class="adder-name">Paint Sourcing Trip</div><div class="adder-sub">If you buy their paint</div></div><div class="adder-amt">+$15-25</div></div>
      </div>
    </div>
    <div class="cat-panel" id="cat-repairs">
      <div class="adder-grid">
        <div class="adder" onclick="toggleAdder(this)" data-min="10" data-max="20" data-label="Nail Holes" data-qty="1" data-qty-label="Number of holes"><div><div class="adder-name">Nail Holes / Small Punctures</div><div class="adder-sub">Spackle, sand, prime</div></div><div class="adder-amt">+$10-20 ea</div></div>
        <div class="adder" onclick="toggleAdder(this)" data-min="40" data-max="80" data-label="Medium Drywall Patch" data-qty="1" data-qty-label="Number of patches"><div><div class="adder-name">Medium Drywall Patch</div><div class="adder-sub">1/2 inch to 4 inch diameter</div></div><div class="adder-amt">+$40-80 ea</div></div>
        <div class="adder" onclick="toggleAdder(this)" data-min="100" data-max="200" data-label="Large Drywall Repair" data-qty="1" data-qty-label="Number of sections"><div><div class="adder-name">Large Drywall Repair</div><div class="adder-sub">4 inch plus full patch</div></div><div class="adder-amt">+$100-200 ea</div></div>
        <div class="adder" onclick="toggleAdder(this)" data-min="30" data-max="60" data-label="Crack Repair" data-qty="1" data-qty-label="Linear feet of cracks"><div><div class="adder-name">Crack Repair</div><div class="adder-sub">Tape, compound, sand per foot</div></div><div class="adder-amt">+$30-60/ft</div></div>
        <div class="adder" onclick="toggleAdder(this)" data-min="75" data-max="150" data-label="Water Damage Spot"><div><div class="adder-name">Water Damage Spot</div><div class="adder-sub">Non-mold, specialty primer</div></div><div class="adder-amt">+$75-150</div></div>
        <div class="adder" onclick="toggleAdder(this)" data-min="20" data-max="40" data-label="Caulking"><div><div class="adder-name">Caulking</div><div class="adder-sub">Tub edge, baseboard, window</div></div><div class="adder-amt">+$20-40</div></div>
      </div>
    </div>
    <div class="cat-panel" id="cat-hanging">
      <div class="adder-grid">
        <div class="adder" onclick="toggleAdder(this)" data-min="75" data-max="125" data-label="TV Mounting up to 45 inch"><div><div class="adder-name">TV Mounting (up to 45")</div><div class="adder-sub">Wall mount, level, secure</div></div><div class="adder-amt">+$75-125</div></div>
        <div class="adder" onclick="toggleAdder(this)" data-min="20" data-max="40" data-label="Picture Hanging" data-qty="1" data-qty-label="Number of pictures"><div><div class="adder-name">Picture Hanging</div><div class="adder-sub">Single frame, level</div></div><div class="adder-amt">+$20-40 ea</div></div>
        <div class="adder" onclick="toggleAdder(this)" data-min="60" data-max="100" data-label="Gallery Wall Setup"><div><div class="adder-name">Gallery Wall Setup</div><div class="adder-sub">Layout and hang multiple frames</div></div><div class="adder-amt">+$60-100</div></div>
        <div class="adder" onclick="toggleAdder(this)" data-min="35" data-max="65" data-label="Mirror Mounting"><div><div class="adder-name">Mirror Mounting</div><div class="adder-sub">Secure wall mount</div></div><div class="adder-amt">+$35-65</div></div>
        <div class="adder" onclick="toggleAdder(this)" data-min="40" data-max="75" data-label="Floating Shelf Install" data-qty="1" data-qty-label="Number of shelves"><div><div class="adder-name">Floating Shelf Install</div><div class="adder-sub">Level, anchor, secure</div></div><div class="adder-amt">+$40-75 ea</div></div>
        <div class="adder" onclick="toggleAdder(this)" data-min="30" data-max="55" data-label="Curtain Rod Install" data-qty="1" data-qty-label="Number of windows"><div><div class="adder-name">Curtain Rod Install</div><div class="adder-sub">Per window</div></div><div class="adder-amt">+$30-55 ea</div></div>
      </div>
    </div>
    <div class="cat-panel" id="cat-other">
      <div class="adder-grid">
        <div class="adder" onclick="toggleAdder(this)" data-min="25" data-max="50" data-label="Smoke Detector Install" data-qty="1" data-qty-label="Number of detectors"><div><div class="adder-name">Smoke Detector Install</div><div class="adder-sub">Per unit</div></div><div class="adder-amt">+$25-50 ea</div></div>
        <div class="adder" onclick="toggleAdder(this)" data-min="50" data-max="100" data-label="Lime Wash Technique"><div><div class="adder-name">Lime Wash Technique</div><div class="adder-sub">Specialty texture finish</div></div><div class="adder-amt">+$50-100</div></div>
        <div class="adder" onclick="toggleAdder(this)" data-min="30" data-max="60" data-label="Touch-Up Painting"><div><div class="adder-name">Touch-Up Painting</div><div class="adder-sub">Scuffs and chips, no full repaint</div></div><div class="adder-amt">+$30-60/room</div></div>
        <div class="adder" onclick="toggleAdder(this)" data-min="20" data-max="40" data-label="Surface Cleaning and Prep"><div><div class="adder-name">Surface Cleaning / Prep</div><div class="adder-sub">Wash walls before paint</div></div><div class="adder-amt">+$20-40</div></div>
      </div>
    </div>
    <div id="qtyInputs" style="margin-top:12px;display:flex;flex-direction:column;gap:8px;"></div>
  </div>

  <div class="live-total">
    <div class="lt-rows">
      <div class="lt-row"><span>Painting Labor</span><span id="ltPainting">$0</span></div>
      <div class="lt-row" id="ltPaintMatRow" style="display:none;"><span>Paint and Materials</span><span id="ltPaintMat">$0</span></div>
      <div class="lt-row" id="ltAddonsRow" style="display:none;"><span>Add-Ons and Services</span><span id="ltAddons">$0</span></div>
      <div class="lt-row" id="ltRushRow" style="display:none;"><span>Rush Surcharge (15%)</span><span id="ltRush">$0</span></div>
      <div class="lt-row total"><span>Estimate Total</span><span id="ltTotal">$0</span></div>
    </div>
    <div class="lt-range" id="ltRange"></div>
    <button class="save-btn" onclick="saveEst()" id="saveBtn" disabled>Save Estimate</button>
  </div>
</div>

<div class="panel" id="panel-files">
  <div style="margin-top:6px;">
    <div class="slabel">Saved Estimates</div>
    <div class="stats-bar">
      <div class="stat"><div class="stat-val" id="sTot">0</div><div class="stat-label">Total Estimates</div></div>
      <div class="stat"><div class="stat-val" id="sVal">$0</div><div class="stat-label">Pipeline Value</div></div>
      <div class="stat"><div class="stat-val" id="sApp">0</div><div class="stat-label">Approved</div></div>
    </div>
    <div class="filter-bar">
      <input type="text" id="srch" placeholder="Search client or address..." oninput="renderFiles()">
      <select id="sfilt" onchange="renderFiles()">
        <option value="">All Statuses</option>
        <option value="pending">Pending</option>
        <option value="approved">Approved</option>
        <option value="declined">Declined</option>
      </select>
    </div>
    <div class="est-list" id="estList"></div>
    <div class="detail-box" id="detailBox"></div>
  </div>
</div>

<script>
let estimates = JSON.parse(localStorage.getItem('hi_ests_v2')||'[]');
let lineCount = 0;

const ROOM_BASE = {
  small:   {min:120, max:150, label:'Small Room / Bathroom'},
  medium:  {min:175, max:225, label:'Medium Room / Bedroom'},
  large:   {min:275, max:350, label:'Large Room'},
  great:   {min:375, max:500, label:'Open / Great Room'},
  hallway: {min:100, max:175, label:'Hallway / Stairwell'},
  dining:  {min:175, max:225, label:'Dining Room'},
};
const SURF_ADD = {
  walls:   {pct:0},
  ceiling: {pct:0.35},
  accent:  {pct:0.2},
  trim:    {pct:0.25},
};

document.getElementById('cDate').value = new Date().toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});
addLine();
renderFiles();

function showPanel(id, btn) {
  document.querySelectorAll('.panel').forEach(function(p){ p.classList.remove('active'); });
  document.querySelectorAll('.ntab').forEach(function(t){ t.classList.remove('active'); });
  document.getElementById('panel-'+id).classList.add('active');
  btn.classList.add('active');
  if (id === 'files') renderFiles();
}

function showCat(id, btn) {
  document.querySelectorAll('.cat-panel').forEach(function(p){ p.classList.remove('active'); });
  document.querySelectorAll('.cat-tab').forEach(function(t){ t.classList.remove('active'); });
  document.getElementById('cat-'+id).classList.add('active');
  btn.classList.add('active');
}

function chipSingle(el, fieldId, val) {
  el.closest('.chips').querySelectorAll('.chip').forEach(function(c){ c.classList.remove('on'); });
  el.classList.add('on');
  document.getElementById(fieldId).value = val;
  updateTotal();
}

function addLine() {
  lineCount++;
  var n = lineCount;
  var div = document.createElement('div');
  div.className = 'job-line';
  div.id = 'line_' + n;

  var top = document.createElement('div');
  top.className = 'jl-top';

  var typeSelect = document.createElement('select');
  typeSelect.id = 'rtype_' + n;
  typeSelect.onchange = updateTotal;
  var typeOpts = [
    ['small','Small Room / Bathroom'],
    ['medium','Medium Room / Bedroom'],
    ['dining','Dining Room'],
    ['large','Large Room'],
    ['great','Open / Great Room'],
    ['hallway','Hallway / Stairwell']
  ];
  typeOpts.forEach(function(o) {
    var opt = document.createElement('option');
    opt.value = o[0];
    opt.textContent = o[1];
    if (o[0] === 'medium') opt.selected = true;
    typeSelect.appendChild(opt);
  });

  var coatSelect = document.createElement('select');
  coatSelect.id = 'rcoats_' + n;
  coatSelect.onchange = updateTotal;
  ['1','2'].forEach(function(c) {
    var opt = document.createElement('option');
    opt.value = c;
    opt.textContent = c + ' coat' + (c==='1'?'':'s');
    if (c === '2') opt.selected = true;
    coatSelect.appendChild(opt);
  });

  var priceDiv = document.createElement('div');
  priceDiv.className = 'jl-price';
  priceDiv.id = 'rprice_' + n;
  priceDiv.textContent = '$0';

  var removeBtn = document.createElement('button');
  removeBtn.className = 'jl-remove';
  removeBtn.textContent = 'x';
  removeBtn.dataset.lineId = 'line_' + n;
  removeBtn.onclick = function() { removeLine(this.dataset.lineId); };

  top.appendChild(typeSelect);
  top.appendChild(coatSelect);
  top.appendChild(priceDiv);
  top.appendChild(removeBtn);

  var surfaces = document.createElement('div');
  surfaces.className = 'jl-surfaces';
  var surfList = [
    ['walls','Walls',true],
    ['ceiling','Ceiling',false],
    ['accent','Accent Wall',false],
    ['trim','Trim',false]
  ];
  surfList.forEach(function(s) {
    var chip = document.createElement('span');
    chip.className = 'surf-chip' + (s[2]?' on':'');
    chip.dataset.surf = s[0];
    chip.textContent = s[1];
    chip.onclick = function() { toggleSurf(this); };
    surfaces.appendChild(chip);
  });

  div.appendChild(top);
  div.appendChild(surfaces);
  document.getElementById('jobLines').appendChild(div);
  updateTotal();
}

function removeLine(id) {
  var el = document.getElementById(id);
  if (el) el.remove();
  updateTotal();
}

function toggleSurf(el) {
  el.classList.toggle('on');
  updateTotal();
}

function toggleAdder(el) {
  el.classList.toggle('on');
  var label = el.dataset.label;
  var hasQty = el.dataset.qty !== undefined;
  var safeId = 'qty_' + label.replace(/[^a-zA-Z0-9]/g,'_');
  if (hasQty) {
    var wrap = document.getElementById(safeId);
    if (!wrap) {
      wrap = document.createElement('div');
      wrap.className = 'qty-wrap show';
      wrap.id = safeId;
      var lbl = document.createElement('label');
      lbl.textContent = el.dataset.qtyLabel || 'Qty';
      var inp = document.createElement('input');
      inp.type = 'number';
      inp.value = '1';
      inp.min = '1';
      inp.style.width = '70px';
      inp.oninput = updateTotal;
      wrap.appendChild(lbl);
      wrap.appendChild(inp);
      document.getElementById('qtyInputs').appendChild(wrap);
    } else {
      wrap.className = el.classList.contains('on') ? 'qty-wrap show' : 'qty-wrap';
    }
  }
  updateTotal();
}

function updateTotal() {
  var paintMin = 0, paintMax = 0;
  var lineEls = document.querySelectorAll('.job-line');
  lineEls.forEach(function(line) {
    var num = line.id.split('_')[1];
    var typeEl = document.getElementById('rtype_' + num);
    var coatEl = document.getElementById('rcoats_' + num);
    var type = typeEl ? typeEl.value : 'medium';
    var coats = coatEl ? parseInt(coatEl.value) : 2;
    var base = ROOM_BASE[type];
    var mn = base.min, mx = base.max;
    var surfs = line.querySelectorAll('.surf-chip.on');
    var surfPct = 0;
    var surfNames = Array.from(surfs).map(function(s){ return s.dataset.surf; });
    surfs.forEach(function(s){ surfPct += SURF_ADD[s.dataset.surf] ? SURF_ADD[s.dataset.surf].pct : 0; });
    if (!surfNames.includes('walls')) { mn = Math.round(mn * 0.6); mx = Math.round(mx * 0.6); }
    mn = Math.round(mn * (1 + surfPct));
    mx = Math.round(mx * (1 + surfPct));
    if (coats === 1) { mn = Math.round(mn * 0.8); mx = Math.round(mx * 0.8); }
    var priceEl = document.getElementById('rprice_' + num);
    if (priceEl) priceEl.textContent = '$' + mn + '-$' + mx;
    paintMin += mn; paintMax += mx;
  });

  var paintMode = document.getElementById('paintMode').value;
  var roomCount = lineEls.length;
  var matMin = 0, matMax = 0;
  if (paintMode === 'us') { matMin = roomCount * 45; matMax = roomCount * 75; }
  document.getElementById('ltPaintMatRow').style.display = paintMode === 'us' ? '' : 'none';
  document.getElementById('ltPaintMat').textContent = paintMode === 'us' ? '$' + matMin + '-$' + matMax : '$0';

  var addMin = 0, addMax = 0, hasRush = false;
  document.querySelectorAll('.adder.on').forEach(function(a) {
    var mn = parseFloat(a.dataset.min) || 0;
    var mx = parseFloat(a.dataset.max) || 0;
    var pct = parseFloat(a.dataset.pct) || 0;
    if (pct > 0) { hasRush = true; return; }
    var safeId = 'qty_' + a.dataset.label.replace(/[^a-zA-Z0-9]/g,'_');
    var qtyEl = document.getElementById(safeId);
    var inp = qtyEl ? qtyEl.querySelector('input') : null;
    var qty = inp ? parseInt(inp.value) || 1 : 1;
    addMin += mn * qty; addMax += mx * qty;
  });
  document.getElementById('ltAddonsRow').style.display = addMin > 0 ? '' : 'none';
  document.getElementById('ltAddons').textContent = addMin > 0 ? '$' + addMin + '-$' + addMax : '$0';

  var rushMin = 0, rushMax = 0;
  if (hasRush) {
    rushMin = Math.round((paintMin + matMin + addMin) * 0.15);
    rushMax = Math.round((paintMax + matMax + addMax) * 0.15);
  }
  document.getElementById('ltRushRow').style.display = hasRush ? '' : 'none';
  document.getElementById('ltRush').textContent = hasRush ? '$' + rushMin + '-$' + rushMax : '$0';

  var totMin = paintMin + matMin + addMin + rushMin;
  var totMax = paintMax + matMax + addMax + rushMax;
  var mid = Math.round((totMin + totMax) / 2);

  document.getElementById('ltPainting').textContent = '$' + paintMin + '-$' + paintMax;
  document.getElementById('ltTotal').textContent = '$' + totMin + '-$' + totMax;
  document.getElementById('ltRange').textContent = totMin > 0 ? 'Midpoint: $' + mid : '';

  var hasClient = document.getElementById('cName').value.trim().length > 0;
  document.getElementById('saveBtn').disabled = !(hasClient && lineEls.length > 0 && totMin > 0);
  return {totMin: totMin, totMax: totMax, mid: mid};
}

function saveEst() {
  var t = updateTotal();
  var lines = [];
  document.querySelectorAll('.job-line').forEach(function(line) {
    var num = line.id.split('_')[1];
    var typeEl = document.getElementById('rtype_' + num);
    var coatEl = document.getElementById('rcoats_' + num);
    var type = typeEl ? typeEl.value : 'medium';
    var coats = coatEl ? coatEl.value : '2';
    var surfs = Array.from(line.querySelectorAll('.surf-chip.on')).map(function(s){ return s.dataset.surf; });
    lines.push({type:type, coats:coats, surfs:surfs, label:ROOM_BASE[type].label});
  });
  var addons = Array.from(document.querySelectorAll('.adder.on')).map(function(a){ return a.dataset.label; });
  var est = {
    id: Date.now(),
    date: new Date().toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}),
    clientName: document.getElementById('cName').value.trim(),
    clientPhone: document.getElementById('cPhone').value,
    jobAddress: document.getElementById('cAddr').value,
    notes: document.getElementById('cNotes').value,
    paintMode: document.getElementById('paintMode').value,
    lines: lines, addons: addons,
    totalMin: t.totMin, totalMax: t.totMax, mid: t.mid,
    status: 'pending'
  };
  estimates.unshift(est);
  localStorage.setItem('hi_ests_v2', JSON.stringify(estimates));
  var btn = document.getElementById('saveBtn');
  btn.textContent = 'Saved!';
  btn.style.background = 'var(--green)';
  setTimeout(function(){ btn.textContent = 'Save Estimate'; btn.style.background = ''; }, 2000);
  renderFiles();
}

function renderFiles() {
  var srch = (document.getElementById('srch') ? document.getElementById('srch').value : '').toLowerCase();
  var sfilt = document.getElementById('sfilt') ? document.getElementById('sfilt').value : '';
  var list = document.getElementById('estList');
  if (!list) return;
  var filt = estimates.filter(function(e) {
    var ms = !srch || e.clientName.toLowerCase().includes(srch) || (e.jobAddress||'').toLowerCase().includes(srch);
    var mf = !sfilt || e.status === sfilt;
    return ms && mf;
  });
  var totVal = estimates.reduce(function(s,e){ return s + e.mid; }, 0);
  var appCount = estimates.filter(function(e){ return e.status === 'approved'; }).length;
  document.getElementById('sTot').textContent = estimates.length;
  document.getElementById('sVal').textContent = '$' + totVal.toLocaleString();
  document.getElementById('sApp').textContent = appCount;
  if (!filt.length) {
    list.innerHTML = '<div class="empty-state"><div style="font-size:2rem;margin-bottom:12px;opacity:.4;">&#128203;</div><div style="font-size:.82rem;">No estimates yet.<br>Build one in the Calculator tab.</div></div>';
    return;
  }
  // Build cards using DOM to avoid any quote issues
  list.innerHTML = '';
  filt.forEach(function(e) {
    var card = document.createElement('div');
    card.className = 'est-card';
    card.dataset.estId = e.id;

    var topDiv = document.createElement('div');
    topDiv.className = 'est-top';

    var leftDiv = document.createElement('div');
    var clientDiv = document.createElement('div');
    clientDiv.className = 'est-client';
    clientDiv.textContent = e.clientName;

    var metaDiv = document.createElement('div');
    metaDiv.className = 'est-meta';
    metaDiv.style.marginTop = '5px';

    var tags = [e.date, e.lines.length + ' area' + (e.lines.length!==1?'s':'')];
    if (e.jobAddress) tags.push(e.jobAddress);
    tags.forEach(function(t) {
      var span = document.createElement('span');
      span.className = 'est-tag';
      span.textContent = t;
      metaDiv.appendChild(span);
    });

    var badge = document.createElement('span');
    badge.className = 'badge ' + e.status;
    badge.textContent = e.status;
    metaDiv.appendChild(badge);

    leftDiv.appendChild(clientDiv);
    leftDiv.appendChild(metaDiv);

    var amtDiv = document.createElement('div');
    amtDiv.className = 'est-amount';
    amtDiv.textContent = '$' + e.totalMin + '-$' + e.totalMax;

    topDiv.appendChild(leftDiv);
    topDiv.appendChild(amtDiv);

    var actDiv = document.createElement('div');
    actDiv.className = 'est-actions';

    var btns = [
      {label:'View', action:function(eid){ openDet(eid); }},
      {label:'Approve', action:function(eid){ updStatus(eid,'approved'); }},
      {label:'Decline', action:function(eid){ updStatus(eid,'declined'); }},
      {label:'Delete', action:function(eid){ delEst(eid); }, danger:true}
    ];
    btns.forEach(function(b) {
      var btn = document.createElement('button');
      btn.className = 'eact' + (b.danger?' danger':'');
      btn.textContent = b.label;
      btn.dataset.estId = e.id;
      btn.onclick = function(ev) {
        ev.stopPropagation();
        b.action(parseInt(this.dataset.estId));
      };
      actDiv.appendChild(btn);
    });

    card.appendChild(topDiv);
    card.appendChild(actDiv);
    card.onclick = function() { openDet(parseInt(this.dataset.estId)); };
    list.appendChild(card);
  });
}

function openDet(id) {
  var e = estimates.find(function(x){ return x.id === id; });
  if (!e) return;
  var box = document.getElementById('detailBox');
  box.className = 'detail-box open';
  box.innerHTML = '';

  // Header
  var head = document.createElement('div');
  head.className = 'det-head';
  var headLeft = document.createElement('div');
  var headName = document.createElement('div');
  headName.className = 'det-name';
  headName.textContent = e.clientName;
  var headSub = document.createElement('div');
  headSub.style.cssText = 'font-size:.7rem;color:var(--dk);margin-top:2px;';
  headSub.textContent = e.date + (e.jobAddress ? ' / ' + e.jobAddress : '');
  headLeft.appendChild(headName);
  headLeft.appendChild(headSub);

  var headRight = document.createElement('div');
  headRight.style.cssText = 'display:flex;gap:8px;';
  var printBtn = document.createElement('button');
  printBtn.textContent = 'Print';
  printBtn.style.cssText = 'background:transparent;border:1px solid var(--border);color:var(--gray);border-radius:4px;padding:5px 12px;cursor:pointer;font-family:Oswald,sans-serif;font-size:.6rem;letter-spacing:.12em;text-transform:uppercase;';
  printBtn.onclick = function(){ window.print(); };
  var closeBtn = document.createElement('button');
  closeBtn.className = 'det-close';
  closeBtn.textContent = 'Close';
  closeBtn.onclick = function(){ document.getElementById('detailBox').className = 'detail-box'; };
  headRight.appendChild(printBtn);
  headRight.appendChild(closeBtn);
  head.appendChild(headLeft);
  head.appendChild(headRight);
  box.appendChild(head);

  function addSection(title) {
    var d = document.createElement('div');
    d.className = 'det-section-title';
    d.textContent = title;
    box.appendChild(d);
  }
  function addRow(label, value) {
    var row = document.createElement('div');
    row.className = 'detail-row';
    var l = document.createElement('span');
    l.textContent = label;
    var v = document.createElement('span');
    v.textContent = value;
    row.appendChild(l);
    row.appendChild(v);
    box.appendChild(row);
  }

  addSection('Job Areas');
  e.lines.forEach(function(l){
    addRow(l.label, l.surfs.join(', ') + ' / ' + l.coats + ' coat' + (l.coats!=='1'?'s':''));
  });

  if (e.addons.length) {
    addSection('Add-Ons and Services');
    e.addons.forEach(function(a){ addRow(a, 'Yes'); });
  }

  addSection('Pricing');
  addRow('Paint supplied by', e.paintMode === 'us' ? 'Holloway Innovation' : 'Client');
  addRow('Estimate range', '$' + e.totalMin + ' - $' + e.totalMax);
  var totRow = document.createElement('div');
  totRow.className = 'detail-row';
  var totL = document.createElement('span');
  totL.textContent = 'Midpoint';
  var totV = document.createElement('span');
  totV.className = 'detail-total';
  totV.textContent = '$' + e.mid;
  totRow.appendChild(totL);
  totRow.appendChild(totV);
  box.appendChild(totRow);

  if (e.notes) {
    addSection('Notes');
    var notesDiv = document.createElement('div');
    notesDiv.style.cssText = 'font-size:.78rem;color:var(--text);line-height:1.6;';
    notesDiv.textContent = e.notes;
    box.appendChild(notesDiv);
  }

  addSection('Status');
  var sel = document.createElement('select');
  sel.className = 'status-sel';
  sel.dataset.estId = e.id;
  ['pending','approved','declined'].forEach(function(s) {
    var opt = document.createElement('option');
    opt.value = s;
    opt.textContent = s.charAt(0).toUpperCase() + s.slice(1);
    if (e.status === s) opt.selected = true;
    sel.appendChild(opt);
  });
  sel.onchange = function() { updStatus(parseInt(this.dataset.estId), this.value); };
  box.appendChild(sel);
  box.scrollIntoView({behavior:'smooth', block:'start'});
}

function updStatus(id, status) {
  var e = estimates.find(function(x){ return x.id === id; });
  if (e) {
    e.status = status;
    localStorage.setItem('hi_ests_v2', JSON.stringify(estimates));
    renderFiles();
  }
}

function delEst(id) {
  if (!confirm('Delete this estimate?')) return;
  estimates = estimates.filter(function(x){ return x.id !== id; });
  localStorage.setItem('hi_ests_v2', JSON.stringify(estimates));
  document.getElementById('detailBox').className = 'detail-box';
  renderFiles();
}
</script>
</body>
</html>
