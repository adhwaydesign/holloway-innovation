<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Request a Quote — The Holloway Innovation</title>
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>

*{box-sizing:border-box;margin:0;padding:0;}
:root{
  --black:#0D0D0D;--orange:#E8541A;--o2:#FF7A45;
  --white:#FFFFFF;--gray:#7A8FA6;--dk:#555;
  --mid:#1A1A1A;--border:#2A2A2A;--text:#CCCCCC;
  --green:#27A060;--teal:#3AACB8;
}
body{background:var(--black);color:var(--text);font-family:'Poppins',sans-serif;font-weight:300;padding-bottom:80px;}
header{background:var(--black);border-bottom:3px solid var(--orange);display:flex;align-items:stretch;}
.hbar{width:8px;background:var(--orange);flex-shrink:0;}
.hlogo{padding:10px 16px;display:flex;align-items:center;}
.hlogo img{height:80px;width:80px;object-fit:contain;background:var(--black);}
.hdoc{padding:18px 24px;text-align:right;display:flex;flex-direction:column;justify-content:center;border-left:1px solid var(--border);margin-left:auto;}
.hdoc-type{font-family:'Oswald',sans-serif;font-weight:700;font-size:1rem;letter-spacing:.12em;color:var(--white);text-transform:uppercase;}
.hdoc-sub{font-size:.6rem;letter-spacing:.2em;color:var(--dk);text-transform:uppercase;margin-top:3px;}
.hdots{display:flex;gap:5px;justify-content:flex-end;margin-top:8px;}
.hdots span{width:9px;height:9px;border-radius:50%;display:block;}
footer{margin-top:60px;border-top:3px solid var(--orange);padding:14px 24px;display:flex;align-items:center;justify-content:space-between;background:var(--mid);}
footer img{height:52px;width:52px;object-fit:contain;background:var(--black);border-radius:4px;}
.ftag{font-family:'Oswald',sans-serif;font-weight:300;font-size:.6rem;letter-spacing:.2em;color:var(--dk);text-transform:uppercase;text-align:right;}

.hero{background:var(--mid);border-bottom:1px solid var(--border);padding:32px 24px;text-align:center;}
.hero h1{font-family:'Oswald',sans-serif;font-weight:700;font-size:1.6rem;letter-spacing:.05em;color:var(--white);margin-bottom:8px;}
.hero h1 span{color:var(--orange);}
.hero p{font-size:.85rem;color:var(--gray);max-width:480px;margin:0 auto;line-height:1.7;}
.container{max-width:640px;margin:0 auto;padding:0 20px;}
.step{margin-top:32px;}
.step-header{display:flex;align-items:center;gap:10px;margin-bottom:14px;}
.step-num{font-family:'Oswald',sans-serif;font-weight:700;font-size:1.8rem;color:var(--orange);opacity:.5;line-height:1;min-width:28px;}
.step-title{font-family:'Oswald',sans-serif;font-weight:700;font-size:1rem;letter-spacing:.1em;color:var(--white);text-transform:uppercase;}
.divider{flex:1;height:1px;background:linear-gradient(to right,var(--border),transparent);}
.field{margin-bottom:14px;}
.field label{display:block;font-family:'Oswald',sans-serif;font-size:.6rem;letter-spacing:.22em;text-transform:uppercase;color:var(--dk);margin-bottom:6px;}
.field label .req{color:var(--orange);}
.field input,.field textarea,.field select{width:100%;background:var(--mid);border:1px solid var(--border);color:var(--white);font-family:'Poppins',sans-serif;font-size:.88rem;font-weight:300;border-radius:6px;padding:10px 14px;outline:none;transition:border-color .18s;}
.field input:focus,.field textarea:focus,.field select:focus{border-color:var(--orange);}
.field textarea{min-height:90px;resize:vertical;}
.field select option{background:var(--black);}
.row{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.chips{display:flex;flex-wrap:wrap;gap:7px;margin-top:6px;}
.chip{font-size:.72rem;border:1px solid var(--border);border-radius:20px;padding:5px 14px;color:var(--gray);cursor:pointer;transition:all .15s;user-select:none;background:var(--mid);}
.chip:hover{border-color:var(--orange);color:var(--o2);}
.chip.on{background:var(--orange);border-color:var(--orange);color:var(--white);font-weight:500;}
.submit-wrap{margin-top:36px;text-align:center;}
.submit-btn{background:var(--orange);color:var(--white);font-family:'Oswald',sans-serif;font-weight:700;font-size:1rem;letter-spacing:.12em;text-transform:uppercase;border:none;border-radius:6px;padding:16px 48px;cursor:pointer;transition:background .18s;width:100%;}
.submit-btn:hover{background:var(--o2);}
.success{display:none;margin-top:32px;background:var(--mid);border:1px solid var(--orange);border-radius:10px;padding:32px;text-align:center;}
.success h2{font-family:'Oswald',sans-serif;font-weight:700;font-size:1.3rem;color:var(--orange);margin-bottom:10px;}
.success p{font-size:.88rem;color:var(--gray);line-height:1.7;}
.note-bar{background:rgba(232,84,26,.08);border:1px solid rgba(232,84,26,.2);border-radius:6px;padding:12px 16px;margin-top:24px;font-size:.75rem;color:var(--gray);line-height:1.6;text-align:center;}
.note-bar strong{color:var(--orange);}
</style>
</head>
<body>
<header>
  <div class="hbar"></div>
  <div class="hlogo">
    <img src="data:image/png;base64," alt="The Holloway Innovation">
  </div>
  <div class="hdoc">
    <div class="hdoc-type">Free Quote</div>
    <div class="hdoc-sub">No Obligation · Response Within 24hrs</div>
    <div class="hdots">
      <span style="background:#E8541A;"></span>
      <span style="background:#fff;"></span>
      <span style="background:#7A8FA6;"></span>
    </div>
  </div>
</header>
<div class="hero">
  <h1>Request a <span>Free Quote</span></h1>
  <p>Fill out the form below and we'll get back to you within 24 hours with a custom estimate. Takes about 2 minutes.</p>
</div>
<div class="container">
  <form id="quoteForm">
    <div class="step">
      <div class="step-header"><div class="step-num">01</div><div class="step-title">Your Info</div><div class="divider"></div></div>
      <div class="row">
        <div class="field"><label>First Name <span class="req">*</span></label><input type="text" name="firstName" required placeholder="First name"></div>
        <div class="field"><label>Last Name <span class="req">*</span></label><input type="text" name="lastName" required placeholder="Last name"></div>
      </div>
      <div class="row">
        <div class="field"><label>Phone Number <span class="req">*</span></label><input type="tel" name="phone" required placeholder="(555) 000-0000"></div>
        <div class="field"><label>Email Address</label><input type="email" name="email" placeholder="Optional"></div>
      </div>
      <div class="field"><label>Property Address <span class="req">*</span></label><input type="text" name="address" required placeholder="Street address, city, zip"></div>
      <div class="field"><label>Best way to reach you</label>
        <div class="chips"><span class="chip" onclick="chipToggle(this,'contactMethod')">Call</span><span class="chip" onclick="chipToggle(this,'contactMethod')">Text</span><span class="chip" onclick="chipToggle(this,'contactMethod')">Email</span></div>
        <input type="hidden" name="contactMethod" id="contactMethod">
      </div>
    </div>
    <div class="step">
      <div class="step-header"><div class="step-num">02</div><div class="step-title">The Space</div><div class="divider"></div></div>
      <div class="field"><label>Which rooms need painting? <span class="req">*</span></label>
        <div class="chips"><span class="chip" onclick="chipToggle(this,'rooms')">Living Room</span><span class="chip" onclick="chipToggle(this,'rooms')">Bedroom(s)</span><span class="chip" onclick="chipToggle(this,'rooms')">Kitchen</span><span class="chip" onclick="chipToggle(this,'rooms')">Bathroom(s)</span><span class="chip" onclick="chipToggle(this,'rooms')">Hallway</span><span class="chip" onclick="chipToggle(this,'rooms')">Dining Room</span><span class="chip" onclick="chipToggle(this,'rooms')">Basement</span><span class="chip" onclick="chipToggle(this,'rooms')">Whole Home</span></div>
        <input type="hidden" name="rooms" id="rooms">
      </div>
      <div class="row">
        <div class="field"><label>How many rooms? <span class="req">*</span></label><select name="roomCount" required><option value="">Select...</option><option>1</option><option>2</option><option>3</option><option>4</option><option>5</option><option>6+</option></select></div>
        <div class="field"><label>Approx. sq footage</label><select name="sqft"><option value="">Not sure</option><option>Under 500 sq ft</option><option>500–1,000 sq ft</option><option>1,000–1,500 sq ft</option><option>1,500–2,000 sq ft</option><option>2,000+ sq ft</option></select></div>
      </div>
      <div class="field"><label>Ceiling height</label>
        <div class="chips"><span class="chip" onclick="chipSingle(this,'ceilHeight')">Standard (8ft)</span><span class="chip" onclick="chipSingle(this,'ceilHeight')">9–10 ft</span><span class="chip" onclick="chipSingle(this,'ceilHeight')">Vaulted / High</span><span class="chip" onclick="chipSingle(this,'ceilHeight')">Not sure</span></div>
        <input type="hidden" name="ceilHeight" id="ceilHeight">
      </div>
    </div>
    <div class="step">
      <div class="step-header"><div class="step-num">03</div><div class="step-title">Wall Conditions</div><div class="divider"></div></div>
      <div class="field"><label>Current wall condition <span class="req">*</span></label>
        <div class="chips"><span class="chip" onclick="chipSingle(this,'wallCond')">Good / Clean</span><span class="chip" onclick="chipSingle(this,'wallCond')">Minor scuffs or holes</span><span class="chip" onclick="chipSingle(this,'wallCond')">Multiple repairs needed</span><span class="chip" onclick="chipSingle(this,'wallCond')">Heavy damage</span></div>
        <input type="hidden" name="wallCond" id="wallCond">
      </div>
      <div class="field"><label>Any water damage, smoke stains, or mold?</label>
        <div class="chips"><span class="chip" onclick="chipSingle(this,'damage')">None</span><span class="chip" onclick="chipSingle(this,'damage')">Water stains</span><span class="chip" onclick="chipSingle(this,'damage')">Smoke / nicotine</span><span class="chip" onclick="chipSingle(this,'damage')">Not sure</span></div>
        <input type="hidden" name="damage" id="damage">
      </div>
      <div class="field"><label>Current wall color (if known)</label><input type="text" name="currentColor" placeholder="e.g. white, beige, dark gray..."></div>
    </div>
    <div class="step">
      <div class="step-header"><div class="step-num">04</div><div class="step-title">Paint Preferences</div><div class="divider"></div></div>
      <div class="field"><label>Paint situation</label>
        <div class="chips"><span class="chip" onclick="chipSingle(this,'paintSit')">I'll supply it</span><span class="chip" onclick="chipSingle(this,'paintSit')">Include in quote</span><span class="chip" onclick="chipSingle(this,'paintSit')">I have a color, you buy</span><span class="chip" onclick="chipSingle(this,'paintSit')">Need recommendations</span></div>
        <input type="hidden" name="paintSit" id="paintSit">
      </div>
      <div class="field"><label>Desired finish</label>
        <div class="chips"><span class="chip" onclick="chipSingle(this,'finish')">Flat / Matte</span><span class="chip" onclick="chipSingle(this,'finish')">Eggshell</span><span class="chip" onclick="chipSingle(this,'finish')">Satin</span><span class="chip" onclick="chipSingle(this,'finish')">Semi-gloss</span><span class="chip" onclick="chipSingle(this,'finish')">Not sure</span></div>
        <input type="hidden" name="finish" id="finish">
      </div>
    </div>
    <div class="step">
      <div class="step-header"><div class="step-num">05</div><div class="step-title">Timeline & Notes</div><div class="divider"></div></div>
      <div class="field"><label>Ideal start timeframe</label>
        <div class="chips"><span class="chip" onclick="chipSingle(this,'timeline')">ASAP</span><span class="chip" onclick="chipSingle(this,'timeline')">Within 2 weeks</span><span class="chip" onclick="chipSingle(this,'timeline')">Within a month</span><span class="chip" onclick="chipSingle(this,'timeline')">Flexible</span></div>
        <input type="hidden" name="timeline" id="timeline">
      </div>
      <div class="field"><label>Is the home currently occupied?</label>
        <div class="chips"><span class="chip" onclick="chipSingle(this,'occupied')">Yes — occupied</span><span class="chip" onclick="chipSingle(this,'occupied')">No — vacant</span></div>
        <input type="hidden" name="occupied" id="occupied">
      </div>
      <div class="field"><label>Anything else we should know?</label><textarea name="notes" placeholder="Special instructions, specific rooms, questions..."></textarea></div>
    </div>
    <div class="note-bar"><strong>No obligation.</strong> This form just helps us prepare an accurate quote for you. We'll reach out within 24 hours.</div>
    <div class="submit-wrap"><button type="submit" class="submit-btn">Submit My Quote Request →</button></div>
  </form>
  <div class="success" id="successMsg">
    <h2>We got it — thank you!</h2>
    <p>We'll review your project details and reach out within 24 hours to schedule your free estimate.<br><br>We appreciate you choosing <strong style="color:var(--orange)">The Holloway Innovation.</strong></p>
  </div>
</div>
<footer>
  <img src="data:image/png;base64," alt="The Holloway Innovation">
  <div>
    <div class="ftag">Interior Painting · Cleveland, OH · Licensed &amp; Insured</div>
  </div>
</footer>
<script>
function chipToggle(el,fieldId){
  el.classList.toggle('on');
  const chips=el.parentElement.querySelectorAll('.chip.on');
  document.getElementById(fieldId).value=Array.from(chips).map(c=>c.textContent).join(', ');
}
function chipSingle(el,fieldId){
  el.parentElement.querySelectorAll('.chip').forEach(c=>c.classList.remove('on'));
  el.classList.add('on');
  document.getElementById(fieldId).value=el.textContent;
}
document.getElementById('quoteForm').addEventListener('submit',function(e){
  e.preventDefault();
  this.style.display='none';
  document.getElementById('successMsg').style.display='block';
  window.scrollTo({top:0,behavior:'smooth'});
});
</script>
</body>
</html>
